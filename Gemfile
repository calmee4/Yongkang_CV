source "https://rubygems.org"

# Use a direct Jekyll setup for local preview so we are not blocked by the
# GitHub Pages meta-gem and its stricter Ruby dependency graph.
gem "jekyll", "~> 4.3.3"
gem "webrick", "~> 1.8"
gem "rexml", "~> 3.2"

gem "wdm", "~> 0.1.0" if Gem.win_platform?

group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"
  gem "jekyll-gist", "~> 1.5"
  gem "jekyll-paginate", "~> 1.1"
  gem "jekyll-redirect-from", "~> 0.16"
  gem "jekyll-sitemap", "~> 1.4"
  gem "jemoji", "~> 0.13"
end
